<navigation-bar title="工时记录" back="{{false}}" color="#111827" background="#F7F8FA"></navigation-bar>

<view class="page">
  <scroll-view
    class="conversation"
    scroll-y
    scroll-with-animation
    type="list"
    scroll-into-view="{{scrollIntoView}}"
  >
    <view class="message-list">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="{{item.id}}"
        class="message message--{{item.role}}"
      >
        <view class="bubble bubble--{{item.status}}">
          <text class="message-text">{{item.content}}</text>

          <view wx:if="{{item.voiceDuration}}" class="voice-meta">
            <view class="voice-bars">
              <view class="voice-bar voice-bar--short"></view>
              <view class="voice-bar"></view>
              <view class="voice-bar voice-bar--tall"></view>
              <view class="voice-bar"></view>
            </view>
            <text class="voice-duration">{{item.voiceDuration}}</text>
          </view>

          <view wx:if="{{item.hasTranscript}}" class="transcript">
            <textarea
              class="transcript-input"
              value="{{item.transcriptText}}"
              placeholder="接口返回后显示转写文字"
              auto-height
              maxlength="-1"
              disabled="{{item.confirmed}}"
              data-id="{{item.id}}"
              bindinput="onTranscriptInput"
            />
            <button
              wx:if="{{!item.confirmed}}"
              class="confirm-button"
              hover-class="confirm-button--hover"
              data-id="{{item.id}}"
              bindtap="onConfirmTranscript"
            >
              确认
            </button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{isRecording}}" class="recording">
    <view class="recording-dot"></view>
    <text class="recording-text">{{recordingText}}</text>
  </view>

  <view class="composer">
    <button
      wx:if="{{!isVoiceMode}}"
      class="mode-button"
      hover-class="mode-button--hover"
      bindtap="switchToVoice"
      disabled="{{isProcessing}}"
      aria-label="语音"
    >
      <view class="mic-icon">
        <view class="mic-head"></view>
        <view class="mic-stem"></view>
        <view class="mic-base"></view>
      </view>
    </button>

    <button
      wx:if="{{isVoiceMode}}"
      class="mode-button"
      hover-class="mode-button--hover"
      bindtap="switchToText"
      disabled="{{isProcessing}}"
      aria-label="键盘"
    >
      <view class="keyboard-icon">
        <view class="keyboard-row">
          <view></view>
          <view></view>
          <view></view>
        </view>
        <view class="keyboard-row keyboard-row--middle">
          <view></view>
          <view></view>
          <view></view>
        </view>
        <view class="keyboard-space"></view>
      </view>
    </button>

    <view wx:if="{{!isVoiceMode}}" class="input-shell" bindtap="focusComposerInput">
      <input
        class="composer-input"
        value="{{inputValue}}"
        placeholder="输入工时内容"
        confirm-type="send"
        cursor-spacing="24"
        adjust-position="{{true}}"
        focus="{{isInputFocused}}"
        bindtap="focusComposerInput"
        bindinput="onInput"
        bindconfirm="onSendTap"
        bindfocus="onComposerFocus"
        bindblur="onComposerBlur"
        disabled="{{isProcessing}}"
      />
    </view>

    <button
      wx:if="{{isVoiceMode}}"
      class="hold-button"
      hover-class="hold-button--active"
      bindtouchstart="onVoiceTouchStart"
      bindtouchend="onVoiceTouchEnd"
      bindtouchcancel="onVoiceTouchCancel"
      disabled="{{isProcessing}}"
    >
      按住 说话
    </button>

    <button
      wx:if="{{!isVoiceMode && inputValue}}"
      class="send-button"
      hover-class="send-button--hover"
      bindtap="onSendTap"
      disabled="{{isProcessing}}"
    >
      发送
    </button>
  </view>
</view>
